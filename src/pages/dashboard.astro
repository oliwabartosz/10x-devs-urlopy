---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import AbsenceGrid from "@/components/absence/AbsenceGrid";
import { createClient } from "@/lib/supabase";
import type { Employee, Absence, AbsenceType } from "@/types";

// month is 1-indexed throughout (matches URL param and Postgres DATE month)
const monthParam = Astro.url.searchParams.get("month");
const now = new Date();
const year = monthParam ? parseInt(monthParam.split("-")[0]) : now.getFullYear();
const month = monthParam ? parseInt(monthParam.split("-")[1]) : now.getMonth() + 1;

// Middleware guarantees user is non-null on this route; guard satisfies TypeScript.
if (!Astro.locals.user) {
  return Astro.redirect("/auth/signin");
}

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) {
  return Astro.redirect("/auth/signin");
}

const { data: currentEmployee } = (await supabase
  .from("employees")
  .select("*")
  .eq("user_id", Astro.locals.user.id)
  .is("deleted_at", null)
  .single()) as { data: Employee | null; error: unknown };

let employees: Employee[] = [];
let absences: Absence[] = [];
let absenceTypes: AbsenceType[] = [];

if (currentEmployee) {
  const firstDay = `${year}-${String(month).padStart(2, "0")}-01`;
  const nextMonthDate = new Date(year, month, 1); // JS month overflow handles Dec→Jan
  const firstDayNextMonth = `${nextMonthDate.getFullYear()}-${String(nextMonthDate.getMonth() + 1).padStart(2, "0")}-01`;

  const [employeesResult, absencesResult, typesResult] = await Promise.all([
    supabase.from("employees").select("*").is("deleted_at", null).order("last_name").order("first_name"),
    supabase.from("absences").select("*").gte("date", firstDay).lt("date", firstDayNextMonth),
    supabase.from("absence_types").select("*").order("id"),
  ]);

  employees = ((employeesResult.data ?? []) as Employee[]);
  absences = ((absencesResult.data ?? []) as Absence[]);
  absenceTypes = ((typesResult.data ?? []) as AbsenceType[]);
}

const prevMonth = new Date(year, month - 2, 1); // month-2 because month is 1-indexed
const nextMonth = new Date(year, month, 1);
const prevMonthUrl = `?month=${prevMonth.getFullYear()}-${String(prevMonth.getMonth() + 1).padStart(2, "0")}`;
const nextMonthUrl = `?month=${nextMonth.getFullYear()}-${String(nextMonth.getMonth() + 1).padStart(2, "0")}`;
---

<Layout title="Urlopy — Ewidencja nieobecności">
  <div class="min-h-screen bg-gray-50">
    <div class="px-4 pt-4">
      <Topbar />
    </div>

    {
      currentEmployee ? (
        <AbsenceGrid
          client:load
          employees={employees}
          absences={absences}
          absenceTypes={absenceTypes}
          currentEmployee={currentEmployee}
          year={year}
          month={month}
          prevMonthUrl={prevMonthUrl}
          nextMonthUrl={nextMonthUrl}
        />
      ) : (
        <div class="p-8 text-center text-gray-600">
          Twoje konto nie jest jeszcze powiązane z kontem pracownika. Skontaktuj się z
          moderatorem.
        </div>
      )
    }
  </div>
</Layout>
