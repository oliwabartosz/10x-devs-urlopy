---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import MonthNav from "@/components/MonthNav.astro";
import AbsenceGrid from "@/components/absence/AbsenceGrid";
import AbsenceDetailsSubcards from "@/components/absence/AbsenceDetailsSubcards";
import AbsenceStats from "@/components/absence/AbsenceStats";
import { createDb, employees as employeesTable, absence_types, absences as absencesTable } from "@/db/index";
import { DATABASE_URL } from "astro:env/server";
import { eq, isNull, and, gte, lt, asc, sql } from "drizzle-orm";
import { EmployeeManagementSheet } from "@/components/employee/EmployeeManagementSheet";
import type { Employee, Absence, AbsenceType } from "@/types";

// month is 1-indexed throughout (matches URL param and Postgres DATE month)
const monthParam = Astro.url.searchParams.get("month");
const now = new Date();
// Normalize to null when format is invalid — prevents NaN propagating into date range queries
const validMonthParam = monthParam != null && /^\d{4}-(?:0[1-9]|1[0-2])$/.test(monthParam) ? monthParam : null;
const year = validMonthParam ? parseInt(validMonthParam.split("-")[0], 10) : now.getFullYear();
const month = validMonthParam ? parseInt(validMonthParam.split("-")[1], 10) : now.getMonth() + 1;

const tabParam = Astro.url.searchParams.get("tab");
const currentTab = tabParam === "details" || tabParam === "stats" ? tabParam : "grid";

const subcardParam = Astro.url.searchParams.get("subcard");
const currentSubcard: "today" | "monthly" | "yearly" =
  subcardParam === "monthly" || subcardParam === "yearly" ? subcardParam : "today";

// Middleware guarantees user is non-null on this route; guard satisfies TypeScript.
if (!Astro.locals.user) {
  return Astro.redirect("/auth/signin");
}

const db = createDb(DATABASE_URL);

let employeeDbError = false;
let currentEmployee: Pick<Employee, "id" | "first_name" | "last_name" | "role"> | null = null;

try {
  const row = await db
    .select({
      id: employeesTable.id,
      first_name: employeesTable.first_name,
      last_name: employeesTable.last_name,
      role: employeesTable.role,
    })
    .from(employeesTable)
    .where(and(eq(employeesTable.user_id, Astro.locals.user.id), isNull(employeesTable.deleted_at)))
    .then((r) => r.at(0) ?? null);
  currentEmployee = row;
} catch {
  employeeDbError = true;
}

let dataDbError = false;
let allEmployees: Employee[] = [];
let gridEmployees: Employee[] = [];
let absences: Absence[] = [];
let absenceTypes: AbsenceType[] = [];

if (currentEmployee) {
  const firstDay = `${year}-${String(month).padStart(2, "0")}-01`;
  const nextMonthDate = new Date(year, month, 1); // JS month overflow handles Dec→Jan
  const firstDayNextMonth = `${nextMonthDate.getFullYear()}-${String(nextMonthDate.getMonth() + 1).padStart(2, "0")}-01`;

  const empCols = {
    id: employeesTable.id,
    user_id: employeesTable.user_id,
    first_name: employeesTable.first_name,
    last_name: employeesTable.last_name,
    role: employeesTable.role,
    deleted_at: employeesTable.deleted_at,
    created_at: employeesTable.created_at,
  };

  const absencesJoin =
    currentEmployee.role === "moderator"
      ? eq(absencesTable.employee_id, employeesTable.id)
      : and(eq(absencesTable.employee_id, employeesTable.id), isNull(employeesTable.deleted_at));

  try {
    const [employeesResult, absencesResult, typesResult] = await Promise.all([
      currentEmployee.role === "moderator"
        ? db.select(empCols).from(employeesTable).orderBy(asc(employeesTable.last_name), asc(employeesTable.first_name))
        : db
            .select(empCols)
            .from(employeesTable)
            .where(isNull(employeesTable.deleted_at))
            .orderBy(asc(employeesTable.last_name), asc(employeesTable.first_name)),
      db
        .select({
          id: absencesTable.id,
          employee_id: absencesTable.employee_id,
          absence_type_id: absencesTable.absence_type_id,
          date: absencesTable.date,
          is_full_day: absencesTable.is_full_day,
          hours: sql<number | null>`${absencesTable.hours}::float`,
          comment: absencesTable.comment,
          substitute_employee_id: absencesTable.substitute_employee_id,
          created_at: absencesTable.created_at,
          updated_at: absencesTable.updated_at,
        })
        .from(absencesTable)
        .innerJoin(employeesTable, absencesJoin)
        .where(and(gte(absencesTable.date, firstDay), lt(absencesTable.date, firstDayNextMonth))),
      db.select().from(absence_types).orderBy(asc(absence_types.id)),
    ]);

    allEmployees = employeesResult;
    gridEmployees =
      currentEmployee.role === "moderator"
        ? employeesResult.filter(
            (e) =>
              e.created_at <= new Date(firstDayNextMonth) &&
              (e.deleted_at === null || e.deleted_at >= new Date(firstDay)),
          )
        : allEmployees;
    absences = absencesResult;
    absenceTypes = typesResult;
  } catch {
    dataDbError = true;
  }
}

// Month param string used in URL construction (always present — fallback to current month)
const monthStr = `${year}-${String(month).padStart(2, "0")}`;

// Month nav URLs preserve the active tab
const prevMonthDate = new Date(year, month - 2, 1); // month-2 because month is 1-indexed
const nextMonthDate = new Date(year, month, 1);
const prevMonthStr = `${prevMonthDate.getFullYear()}-${String(prevMonthDate.getMonth() + 1).padStart(2, "0")}`;
const nextMonthStr = `${nextMonthDate.getFullYear()}-${String(nextMonthDate.getMonth() + 1).padStart(2, "0")}`;
const prevMonthUrl =
  currentTab === "details"
    ? `?month=${prevMonthStr}&tab=${currentTab}&subcard=${currentSubcard}`
    : `?month=${prevMonthStr}&tab=${currentTab}`;
const nextMonthUrl =
  currentTab === "details"
    ? `?month=${nextMonthStr}&tab=${currentTab}&subcard=${currentSubcard}`
    : `?month=${nextMonthStr}&tab=${currentTab}`;

// Tab nav URLs preserve the current month
const gridTabUrl = `?month=${monthStr}&tab=grid`;
const detailsTabUrl = `?month=${monthStr}&tab=details&subcard=today`;
const statsTabUrl = `?month=${monthStr}&tab=stats`;
---

<Layout title="Urlopy — Ewidencja nieobecności">
  <div class="min-h-screen bg-gray-50">
    <div class="px-4 pt-4">
      <Topbar role={currentEmployee?.role} />
      {
        currentEmployee?.role === "moderator" && (
          <div class="mt-2">
            <EmployeeManagementSheet client:load employees={allEmployees} currentEmployee={currentEmployee} />
          </div>
        )
      }
    </div>

    {
      employeeDbError || dataDbError ? (
        <div class="p-8 text-center text-red-600">
          Błąd serwera. Spróbuj ponownie lub skontaktuj się z administratorem.
        </div>
      ) : currentEmployee ? (
        <div class="px-4 pt-4">
          <MonthNav prevMonthUrl={prevMonthUrl} nextMonthUrl={nextMonthUrl} year={year} month={month} />

          <nav class="mt-3 flex gap-1 border-b">
            <a
              href={gridTabUrl}
              class:list={`px-4 py-2 text-sm font-medium ${currentTab === "grid" ? "border-b-2 border-blue-600 text-blue-600" : "text-gray-600 hover:text-gray-900"}`}
            >
              Siatka
            </a>
            <a
              href={detailsTabUrl}
              class:list={`px-4 py-2 text-sm font-medium ${currentTab === "details" ? "border-b-2 border-blue-600 text-blue-600" : "text-gray-600 hover:text-gray-900"}`}
            >
              Szczegóły
            </a>
            <a
              href={statsTabUrl}
              class:list={`px-4 py-2 text-sm font-medium ${currentTab === "stats" ? "border-b-2 border-blue-600 text-blue-600" : "text-gray-600 hover:text-gray-900"}`}
            >
              Statystyki
            </a>
          </nav>

          <div class="mt-4">
            {currentTab === "grid" && (
              <AbsenceGrid
                client:load
                employees={gridEmployees}
                absences={absences}
                absenceTypes={absenceTypes}
                currentEmployee={currentEmployee}
                year={year}
                month={month}
              />
            )}
            {currentTab === "details" && (
              <AbsenceDetailsSubcards
                client:load
                absences={absences}
                employees={gridEmployees}
                absenceTypes={absenceTypes}
                year={year}
                month={month}
                initialSubcard={currentSubcard}
              />
            )}
            {currentTab === "stats" && (
              <AbsenceStats
                client:load
                monthlyAbsences={absences}
                employees={gridEmployees}
                absenceTypes={absenceTypes}
                year={year}
                month={month}
              />
            )}
          </div>
        </div>
      ) : (
        <div class="p-8 text-center text-gray-600">
          Twoje konto nie jest jeszcze powiązane z kontem pracownika. Skontaktuj się z moderatorem.
        </div>
      )
    }
  </div>
</Layout>
