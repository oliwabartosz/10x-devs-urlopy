{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "urlopy",
  "main": "./sentry.server.config.ts",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
  "observability": {
    "enabled": true,
  },
}
