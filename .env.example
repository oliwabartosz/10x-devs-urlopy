SUPABASE_URL=###
SUPABASE_KEY=###
SUPABASE_SERVICE_KEY=###
DATABASE_URL=postgresql://postgres.[project-ref]:[DB_PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres:[DB_PASSWORD]@db.[project-ref].supabase.co:5432/postgres

# E2E tests (Playwright) — credentials for the test user account
E2E_USER_EMAIL=oliwa.bartosz@gmail.com
E2E_USER_PASSWORD=###

# Sentry — source map upload token (build-time only, not a runtime secret).
# Also optionally read by `npm run digest` to list new Sentry issues; without it
# the digest's Sentry section is simply skipped ("niedostępne").
SENTRY_AUTH_TOKEN=###
# Sentry — DSN for error reporting (wrangler dev runtime + production Worker)
SENTRY_DSN=###

# SUPER-ADMIN CREDENTIALS — consumed by `npm run seed:admin` (one-time-per-environment, runs in Node).
# Creates the hidden technical admin (role: moderator, is_system=true) via the Supabase
# service-role key + a Drizzle insert over DATABASE_URL_DIRECT. Re-running is a no-op.
ADMIN_LOGIN=admin@your-email.com
ADMIN_PASSWORD=admin-password-goes-here
